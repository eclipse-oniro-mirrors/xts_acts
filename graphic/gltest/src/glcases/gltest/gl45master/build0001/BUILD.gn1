config("deqp_platform_ohos_config") {
  cflags_cc = deqp_common_cflags_cc

  cflags_cc += [
      # "-Wno-conversion",
      # "-Wno-unused-function",
      "-Wno-unused-parameter",
    ]
  
  defines = deqp_common_defines
  # defines -=["DE_PTR_SIZE=8"]
  # defines += [
  #   "DE_PTR_SIZE=4", 
  #   "_XOPEN_SOURCE=600"
  # ]
}


